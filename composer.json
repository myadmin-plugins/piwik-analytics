{
    "name": "detain/myadmin-piwik-analytics",
    "type": "myadmin-plugin",
    "description": "Piwik/Matomo analytics integration plugin for the MyAdmin control-panel framework",
    "keywords": [
        "piwik",
        "matomo",
        "analytics",
        "myadmin",
        "plugin"
    ],
    "license": "LGPL-2.1-only",
    "authors": [
        {
            "name": "Joe Huss",
            "homepage": "https://my.interserver.net/"
        }
    ],
    "config": {
        "bin-dir": "vendor/bin",
        "minimum-stability": "dev",
        "allow-plugins": {
            "detain/myadmin-plugin-installer": true
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-soap": "*",
        "symfony/event-dispatcher": "^5.0|^6.0|^7.0",
        "detain/myadmin-plugin-installer": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Detain\\MyAdminPiwik\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Detain\\MyAdminPiwik\\Tests\\": "tests/"
        }
    }
}
